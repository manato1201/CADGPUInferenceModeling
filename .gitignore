# ── Python 仮想環境 ────────────────────────────
.venv/
venv/
env/

# ── Python キャッシュ ──────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── HuggingFace モデルキャッシュ ───────────────
# (~4GB のモデルは個人PCのキャッシュに任せる)
.cache/
*.bin
*.safetensors
*.ckpt
*.pt
*.pth

# ── パイプライン出力物 ─────────────────────────
# 生成されたアセットはリポジトリに含めない
out/
output/
api_workspace/

# ── 入力 CAD ファイル ──────────────────────────
# ライセンス上問題がある場合はコメントアウトして除外
# *.dxf
# *.dwg

# ── ログ・一時ファイル ─────────────────────────
*.log
*.tmp
*.bak

# ── OS 生成ファイル ────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── エディタ ───────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── 外部リポジトリ（サブモジュールではなく単純clone）──
TripoSR/